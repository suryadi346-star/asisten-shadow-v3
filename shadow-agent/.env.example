# Shadow Agent — Environment Variables
# Copy file ini ke .env dan isi API key lo

# ── AI Providers ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Default Provider ────────────────────────────────────
# "anthropic" atau "openai"
DEFAULT_PROVIDER=anthropic

# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
DEBUG=false

# ── Database ────────────────────────────────────────────
DB_PATH=data/shadow.db
